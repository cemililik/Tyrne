# Rust build output
/target/
**/target/
**/*.rs.bk
Cargo.lock.orig

# Kernel / bootloader artifacts
*.elf
*.bin
*.img
*.iso
*.o
*.obj
*.a
*.lib
*.pdb

# Emulator / debugger state
*.qcow2
*.serial.log
gdb.txt
.gdb_history

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*.iml
.DS_Store
Thumbs.db

# Local env
.env
.env.local
.env.*.local

# Logs and temp
*.log
tmp/
.tmp/

# Claude Code runtime state — per-session lock files coordinating tools like
# ScheduleWakeup. The .claude/skills/ tree itself IS tracked (project skills
# are source of truth); only runtime lock files are ignored.
.claude/*.lock

# Python tooling occasionally used for build scripts
__pycache__/
*.pyc
.venv/

# Local-only technical analyses (reading notes on external codebases)
docs/analysis/technical-analysis/

# Local-only transient workbooks (follow-up ledgers, drafts, scratch notes)
docs/analysis/temp/

# Coverage raw artefacts — summary reports are committed under
# docs/analysis/reports/, but raw lcov/profraw dumps are not (they change
# on every run and bloat diffs).
*.profraw
docs/analysis/reports/lcov-*.info
